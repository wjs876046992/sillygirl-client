<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme (simplified to avoid missing color refs) -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">#1890ff</item>
        <item name="colorPrimaryDark">#1070c2</item>
        <item name="colorAccent">#1890ff</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.AppCompat.NoActionBar">
        <item name="android:background">#ffffff</item>
    </style>
</resources>
